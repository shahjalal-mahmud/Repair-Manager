## Local Configuration Resource Example
# This file is a placeholder template for local environment variables.
# Copy the contents of this file into a new file named 'local.properties'
# in this same directory and supply your actual keys.

# Location of the SDK. This is usually auto-generated by Android Studio.
# sdk.dir=C\:\\Users\\YOUR_USERNAME\\AppData\\Local\\Android\\Sdk

# Firebase Google Sign-In Configuration
# Replace the placeholder below with your project's Web Client ID from the Firebase Console
# (Project Settings -> Authentication -> Google -> Web SDK configuration)
WEB_CLIENT_ID="YOUR_WEB_CLIENT_ID_GOES_HERE.apps.googleusercontent.com"